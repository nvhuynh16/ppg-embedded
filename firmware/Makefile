# Build the PPG firmware for ARM Cortex-M3 (QEMU lm3s6965evb).
# Requires: gcc-arm-none-eabi (provides arm-none-eabi-gcc + nosys.specs).
#
# Targets:
#   make                  → firmware.elf       (peak-detector HR path)
#   make USE_FFT=1        → firmware_fft.elf   (256-pt Q15 FFT spectral HR path)
#   make host-test        → host build + run of the peak-detector DSP canary
#   make host-fft-test    → host build + run of the FFT bit-exactness canary
#   make run              → builds firmware.elf and launches QEMU
#   make run-fft          → builds firmware_fft.elf and launches QEMU on it

CROSS  ?= arm-none-eabi-
CC      = $(CROSS)gcc

CFLAGS  = -mcpu=cortex-m3 -mthumb -O2 -g3 -ffreestanding -Wall -Wextra -I. \
          -ffunction-sections -fdata-sections
LDFLAGS = -T lm3s6965.ld -nostartfiles --specs=nosys.specs -Wl,--gc-sections

SRCS     = startup.c main.c dsp_fixed.c
FFT_SRCS = startup.c main_fft.c dsp_fixed.c dsp_fft.c
RR_SRCS  = startup.c main_rr.c dsp_fixed.c dsp_resp.c
SQI_SRCS = startup.c main_sqi.c dsp_cnn.c

firmware.elf: $(SRCS) generated/ppg_data.h lm3s6965.ld
	$(CC) $(CFLAGS) $(LDFLAGS) -o $@ $(SRCS)

firmware_fft.elf: $(FFT_SRCS) generated/ppg_data.h generated/fft_data.h dsp_fft.h lm3s6965.ld
	$(CC) $(CFLAGS) $(LDFLAGS) -o $@ $(FFT_SRCS)

firmware_rr.elf: $(RR_SRCS) generated/ppg_data.h generated/resp_data.h dsp_resp.h lm3s6965.ld
	$(CC) $(CFLAGS) $(LDFLAGS) -o $@ $(RR_SRCS)

firmware_sqi.elf: $(SQI_SRCS) generated/cnn_data.h dsp_cnn.h lm3s6965.ld
	$(CC) $(CFLAGS) $(LDFLAGS) -o $@ $(SQI_SRCS)

run: firmware.elf
	bash run_qemu.sh

run-fft: firmware_fft.elf
	bash run_qemu.sh firmware_fft.elf

run-rr: firmware_rr.elf
	bash run_qemu.sh firmware_rr.elf

# Host-side DSP canary: build dsp_fixed.c + host_test.c with the system gcc and run.
# Skips the cross-compile / QEMU path entirely — fast feedback for the DSP code alone.
HOST_CC     ?= gcc
HOST_CFLAGS ?= -O2 -Wall -Wextra -I.

host_test: host_test.c dsp_fixed.c generated/ppg_data.h
	$(HOST_CC) $(HOST_CFLAGS) -o $@ host_test.c dsp_fixed.c

host-test: host_test
	./host_test

# Host-side FFT bit-exactness canary — links dsp_fft.c against host_fft_test.c, runs
# the same N-point FFT in C and prints the spectrum so reference.py can compare it
# against numpy.fft of the same input.
host_fft_test: host_fft_test.c dsp_fft.c generated/ppg_data.h generated/fft_data.h dsp_fft.h
	$(HOST_CC) $(HOST_CFLAGS) -o $@ host_fft_test.c dsp_fft.c -lm

host-fft-test: host_fft_test
	./host_fft_test

# --- Unity unit tests ---
# Build host-side; sub-second feedback. Use the same HOST_CFLAGS as the canaries
# but add -Wno-unused-parameter for Unity's TEST_ASSERT macros and -DUNITY_INCLUDE_DOUBLE
# is NOT required (we only use the int / uint families).
UNITY_CFLAGS = $(HOST_CFLAGS) -Wno-unused-parameter

test_dsp_fixed: test_dsp_fixed.c dsp_fixed.c unity.c
	$(HOST_CC) $(UNITY_CFLAGS) -o $@ test_dsp_fixed.c dsp_fixed.c unity.c -lm

test_dsp_fft: test_dsp_fft.c dsp_fft.c unity.c generated/fft_data.h dsp_fft.h
	$(HOST_CC) $(UNITY_CFLAGS) -o $@ test_dsp_fft.c dsp_fft.c unity.c -lm

test: test_dsp_fixed test_dsp_fft
	@echo "--- test_dsp_fixed ---"
	@./test_dsp_fixed
	@echo "--- test_dsp_fft ---"
	@./test_dsp_fft

# --- gcov line coverage ---
# Rebuilds the Unity suites with --coverage instrumentation, runs them, then
# invokes gcov on the DSP source files. Writes a summary to results/coverage.md.
COV_CFLAGS = $(HOST_CFLAGS) -Wno-unused-parameter --coverage -O0

test_dsp_fixed_cov: test_dsp_fixed.c dsp_fixed.c unity.c
	$(HOST_CC) $(COV_CFLAGS) -o $@ test_dsp_fixed.c dsp_fixed.c unity.c -lm

test_dsp_fft_cov: test_dsp_fft.c dsp_fft.c unity.c generated/fft_data.h dsp_fft.h
	$(HOST_CC) $(COV_CFLAGS) -o $@ test_dsp_fft.c dsp_fft.c unity.c -lm

coverage: test_dsp_fixed_cov test_dsp_fft_cov
	@./test_dsp_fixed_cov > /dev/null
	@./test_dsp_fft_cov   > /dev/null
	@# gcc prefixes the .gcda files with the executable name; pass them explicitly.
	@gcov -n -r test_dsp_fixed_cov-dsp_fixed.gcda \
	             test_dsp_fft_cov-dsp_fft.gcda 2>&1 \
	  | grep -E "(File|Lines executed)" | tee /tmp/gcov.log
	@mkdir -p ../results
	@{ \
	  echo "# Line coverage (gcov, generated by \`make -C firmware coverage\`)"; \
	  echo; \
	  echo "Source instrumentation: \`-fprofile-arcs -ftest-coverage -O0\`."; \
	  echo "Tests: \`firmware/test_dsp_fixed.c\` + \`firmware/test_dsp_fft.c\` (Unity)."; \
	  echo; \
	  echo '```'; \
	  cat /tmp/gcov.log; \
	  echo '```'; \
	} > ../results/coverage.md
	@echo "wrote results/coverage.md"

clean:
	rm -f firmware.elf firmware_fft.elf firmware_rr.elf \
	      host_test host_fft_test \
	      test_dsp_fixed test_dsp_fft \
	      test_dsp_fixed_cov test_dsp_fft_cov \
	      *.gcno *.gcda *.gcov

.PHONY: run run-fft run-rr host-test host-fft-test test coverage clean
